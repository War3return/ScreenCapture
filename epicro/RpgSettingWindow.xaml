<Window x:Class="epicro.RpgSettingWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="RPG 세이브 설정" Height="480" Width="720"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        Background="{StaticResource BgPrimaryBrush}"
        Loaded="Window_Loaded">

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="160"/>
            <ColumnDefinition Width="8"/>
            <ColumnDefinition Width="160"/>
            <ColumnDefinition Width="8"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- ── RPG 리스트 ── -->
        <DockPanel Grid.Row="0" Grid.Column="0">
            <TextBlock DockPanel.Dock="Top" Text="RPG 리스트"
                       FontSize="10" Foreground="{StaticResource TextSecondaryBrush}"
                       Margin="0,0,0,4"/>
            <Button DockPanel.Dock="Bottom" x:Name="btn_RpgRefresh" Content="새로고침"
                    Margin="0,4,0,0" Click="btn_RpgRefresh_Click"/>
            <ListBox x:Name="lst_RpgList"
                     DisplayMemberPath="DisplayName"
                     SelectionChanged="lst_RpgList_SelectionChanged"/>
        </DockPanel>

        <!-- ── 저장 분류 리스트 ── -->
        <DockPanel Grid.Row="0" Grid.Column="2">
            <TextBlock DockPanel.Dock="Top" Text="저장 분류 리스트"
                       FontSize="10" Foreground="{StaticResource TextSecondaryBrush}"
                       Margin="0,0,0,4"/>
            <ListBox x:Name="lst_CategoryList"
                     SelectionChanged="lst_CategoryList_SelectionChanged"/>
        </DockPanel>

        <!-- ── 설정 패널 ── -->
        <ScrollViewer Grid.Row="0" Grid.Column="4" VerticalScrollBarVisibility="Auto">
            <StackPanel>

                <!-- RPG 설정 -->
                <Border Background="{StaticResource BgCardBrush}"
                        CornerRadius="8" Padding="12,10" Margin="0,0,0,8">
                    <StackPanel>
                        <TextBlock Text="RPG 설정" FontWeight="SemiBold" FontSize="11"
                                   Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,8"/>

                        <TextBlock Text="한글" FontSize="10"
                                   Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,2"/>
                        <TextBox x:Name="txt_RpgNameKR" Margin="0,0,0,6"/>

                        <TextBlock Text="영문" FontSize="10"
                                   Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,2"/>
                        <TextBox x:Name="txt_RpgNameEN" Margin="0,0,0,6"/>

                        <TextBlock Text="경로" FontSize="10"
                                   Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,2"/>
                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="4"/>
                                <ColumnDefinition Width="28"/>
                            </Grid.ColumnDefinitions>
                            <TextBox x:Name="txt_RpgPath" Grid.Column="0" IsReadOnly="True"/>
                            <Button Grid.Column="2" Content="..." Click="btn_BrowsePath_Click"/>
                        </Grid>

                        <UniformGrid Columns="3">
                            <Button Content="추가"      Margin="0,0,2,0" Click="btn_RpgAdd_Click"/>
                            <Button Content="제거"      Margin="2,0,2,0" Click="btn_RpgRemove_Click"/>
                            <Button Content="폴더 열기" Margin="2,0,0,0" Click="btn_RpgOpenFolder_Click"/>
                        </UniformGrid>
                    </StackPanel>
                </Border>

                <!-- 저장 분류 설정 -->
                <Border Background="{StaticResource BgCardBrush}"
                        CornerRadius="8" Padding="12,10">
                    <StackPanel>
                        <TextBlock Text="저장 분류 설정" FontWeight="SemiBold" FontSize="11"
                                   Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,8"/>

                        <TextBlock Text="이름" FontSize="10"
                                   Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,2"/>
                        <TextBox x:Name="txt_CategoryName" Margin="0,0,0,8"/>

                        <UniformGrid Columns="3">
                            <Button Content="추가"      Margin="0,0,2,0" Click="btn_CategoryAdd_Click"/>
                            <Button Content="삭제"      Margin="2,0,2,0" Click="btn_CategoryDelete_Click"/>
                            <Button Content="폴더 열기" Margin="2,0,0,0" Click="btn_CategoryOpenFolder_Click"/>
                        </UniformGrid>
                    </StackPanel>
                </Border>

            </StackPanel>
        </ScrollViewer>

        <!-- ── 하단 지정 바 ── -->
        <Border Grid.Row="1" Grid.ColumnSpan="5"
                Background="{StaticResource BgCardBrush}"
                CornerRadius="8" Padding="10,8" Margin="0,8,0,0">
            <DockPanel>
                <Button DockPanel.Dock="Right" Content="지정"
                        Width="70" Click="btn_SetCurrent_Click"/>
                <StackPanel VerticalAlignment="Center" Margin="0,0,10,0">
                    <TextBlock Text="세이브 저장 위치"
                               FontSize="10" Foreground="{StaticResource TextSecondaryBrush}"/>
                    <TextBlock x:Name="lbl_CurrentDesignation"
                               Text="(지정 없음)" FontSize="11"
                               Foreground="{StaticResource TextPrimaryBrush}"/>
                </StackPanel>
            </DockPanel>
        </Border>
    </Grid>
</Window>
