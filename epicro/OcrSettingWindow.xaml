<Window x:Class="epicro.OcrSettingWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="OCR 설정" Height="500" Width="500"
        MinHeight="520" MinWidth="440"
        ResizeMode="CanResize" WindowStartupLocation="CenterOwner"
        Icon="/epicro_sub.ico"
        Background="{StaticResource BgPrimaryBrush}">

    <!-- 루트를 Grid로 변경 → 이미지 영역(*행)이 창 크기에 맞게 늘어남 -->
    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>   <!-- 안내 텍스트 -->
            <RowDefinition Height="*" MinHeight="200"/>  <!-- 이미지 미리보기 (가변) -->
            <RowDefinition Height="Auto"/>   <!-- 문자 색상 필터 -->
            <RowDefinition Height="Auto"/>   <!-- 배경 색상 필터 -->
            <RowDefinition Height="Auto"/>   <!-- OCR 테스트 -->
            <RowDefinition Height="Auto"/>   <!-- 버튼 -->
        </Grid.RowDefinitions>

        <!-- 안내 -->
        <TextBlock Grid.Row="0"
                   Text="좌측 원본 이미지에서 색상을 선택하여 문자·배경을 분리하십시오."
                   Foreground="{StaticResource TextSecondaryBrush}"
                   FontSize="11" TextWrapping="Wrap" Margin="0,0,0,8"/>

        <!-- 이미지 미리보기 (창 크기 따라 가변) -->
        <Grid Grid.Row="1" Margin="0,0,0,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="10"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- 원본 -->
            <Grid Grid.Column="0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Text="원본"
                           Foreground="{StaticResource TextSecondaryBrush}"
                           FontSize="10" Margin="0,0,0,3"/>

                <Border Grid.Row="1"
                        BorderBrush="{StaticResource BorderBrush_}" BorderThickness="1"
                        CornerRadius="4">
                    <ScrollViewer HorizontalScrollBarVisibility="Auto"
                                  VerticalScrollBarVisibility="Auto"
                                  CanContentScroll="False">
                        <Image Name="OriginalImage" Stretch="None"
                               MouseDown="OriginalImage_MouseDown">
                            <Image.LayoutTransform>
                                <ScaleTransform x:Name="ZoomTransform" ScaleX="2" ScaleY="2"/>
                            </Image.LayoutTransform>
                        </Image>
                    </ScrollViewer>
                </Border>

                <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,5,0,0">
                    <TextBlock Text="확대:" Foreground="{StaticResource TextSecondaryBrush}"
                               FontSize="10" VerticalAlignment="Center" Margin="0,0,5,0"/>
                    <Slider x:Name="ZoomSlider" Minimum="1" Maximum="10" Value="2"
                            Width="120" VerticalAlignment="Center"
                            ValueChanged="ZoomSlider_ValueChanged"/>
                    <TextBlock Text="{Binding ElementName=ZoomSlider, Path=Value, StringFormat=F1}"
                               Foreground="{StaticResource TextSecondaryBrush}"
                               FontSize="10" Margin="5,0,0,0" VerticalAlignment="Center"/>
                </StackPanel>
            </Grid>

            <!-- 필터 결과 -->
            <Grid Grid.Column="2">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Text="필터 결과"
                           Foreground="{StaticResource TextSecondaryBrush}"
                           FontSize="10" Margin="0,0,0,3"/>

                <Border Grid.Row="1"
                        BorderBrush="{StaticResource BorderBrush_}" BorderThickness="1"
                        CornerRadius="4">
                    <ScrollViewer HorizontalScrollBarVisibility="Auto"
                                  VerticalScrollBarVisibility="Auto"
                                  CanContentScroll="False">
                        <Image Name="FilteredImage" Stretch="None">
                            <Image.LayoutTransform>
                                <ScaleTransform x:Name="FillterdZoomTransform" ScaleX="2" ScaleY="2"/>
                            </Image.LayoutTransform>
                        </Image>
                    </ScrollViewer>
                </Border>

                <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,4,0,0">
                    <TextBlock Text="확대:" Foreground="{StaticResource TextSecondaryBrush}"
                               FontSize="10" VerticalAlignment="Center" Margin="0,0,4,0"/>
                    <Slider x:Name="FillteredZoomSlider" Minimum="1" Maximum="10" Value="2"
                            Width="100" VerticalAlignment="Center"
                            ValueChanged="FillteredZoomSlider_ValueChanged"/>
                    <TextBlock Text="{Binding ElementName=FillteredZoomSlider, Path=Value, StringFormat=F1}"
                               Foreground="{StaticResource TextSecondaryBrush}"
                               FontSize="10" Margin="4,0,0,0" VerticalAlignment="Center"/>
                </StackPanel>
            </Grid>
        </Grid>

        <!-- 문자 색상 필터 -->
        <GroupBox Grid.Row="2" Header="문자 색상 필터" Margin="0,0,0,8">
            <StackPanel>
                <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                    <CheckBox x:Name="CheckBox1" Content="색상 1" Width="60"
                              VerticalAlignment="Center" Click="CheckBox1_Click"/>
                    <Rectangle x:Name="Rectangle1" Width="20" Height="20"
                               Stroke="{StaticResource BorderBrush_}" StrokeThickness="1"
                               RadiusX="3" RadiusY="3" Margin="6,0"/>
                    <TextBlock Text="범위" Foreground="{StaticResource TextSecondaryBrush}"
                               FontSize="11" VerticalAlignment="Center" Margin="0,0,6,0"/>
                    <Slider x:Name="Slider1" Minimum="0" Maximum="64"
                            HorizontalAlignment="Stretch" MinWidth="80"
                            VerticalAlignment="Center" ValueChanged="ColorSlider_ValueChanged"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                    <CheckBox x:Name="CheckBox2" Content="색상 2" Width="60"
                              VerticalAlignment="Center" Click="CheckBox2_Click"/>
                    <Rectangle x:Name="Rectangle2" Width="20" Height="20"
                               Stroke="{StaticResource BorderBrush_}" StrokeThickness="1"
                               RadiusX="3" RadiusY="3" Margin="6,0"/>
                    <TextBlock Text="범위" Foreground="{StaticResource TextSecondaryBrush}"
                               FontSize="11" VerticalAlignment="Center" Margin="0,0,6,0"/>
                    <Slider x:Name="Slider2" Minimum="0" Maximum="64"
                            HorizontalAlignment="Stretch" MinWidth="80"
                            VerticalAlignment="Center" ValueChanged="ColorSlider_ValueChanged"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal">
                    <CheckBox x:Name="CheckBox3" Content="색상 3" Width="60"
                              VerticalAlignment="Center" Click="CheckBox3_Click"/>
                    <Rectangle x:Name="Rectangle3" Width="20" Height="20"
                               Stroke="{StaticResource BorderBrush_}" StrokeThickness="1"
                               RadiusX="3" RadiusY="3" Margin="6,0"/>
                    <TextBlock Text="범위" Foreground="{StaticResource TextSecondaryBrush}"
                               FontSize="11" VerticalAlignment="Center" Margin="0,0,6,0"/>
                    <Slider x:Name="Slider3" Minimum="0" Maximum="64"
                            HorizontalAlignment="Stretch" MinWidth="80"
                            VerticalAlignment="Center" ValueChanged="ColorSlider_ValueChanged"/>
                </StackPanel>
            </StackPanel>
        </GroupBox>

        <!-- 배경 색상 필터 -->
        <GroupBox Grid.Row="3" Header="배경 색상 필터" Margin="0,0,0,10">
            <StackPanel Orientation="Horizontal">
                <CheckBox x:Name="CheckBoxBG" Content="배경" Width="60"
                          VerticalAlignment="Center" Click="CheckBoxBG_Click"/>
                <Rectangle x:Name="RectangleBG" Width="20" Height="20"
                           Stroke="{StaticResource BorderBrush_}" StrokeThickness="1"
                           RadiusX="3" RadiusY="3" Margin="6,0"/>
                <TextBlock Text="범위" Foreground="{StaticResource TextSecondaryBrush}"
                           FontSize="11" VerticalAlignment="Center" Margin="0,0,6,0"/>
                <Slider x:Name="SliderBG" Minimum="0" Maximum="64"
                        HorizontalAlignment="Stretch" MinWidth="80"
                        VerticalAlignment="Center" ValueChanged="ColorSlider_ValueChanged"/>
            </StackPanel>
        </GroupBox>

        <!-- OCR 테스트 -->
        <StackPanel Grid.Row="4" Orientation="Horizontal" Margin="0,0,0,10">
            <Button x:Name="OcrTestButton" Content="OCR 테스트" Width="100"
                    Background="#2E2F4A" Click="OcrTestButton_Click" Margin="0,0,8,0"/>
            <TextBox x:Name="OcrResultBox" HorizontalAlignment="Stretch" IsReadOnly="True"
                     Background="{StaticResource BgSurfaceBrush}"/>
        </StackPanel>

        <!-- 확인/닫기 -->
        <StackPanel Grid.Row="5" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="적용" Width="80" Margin="0,0,8,0" Click="Button_Click"/>
            <Button Content="닫기" Width="80" Background="#3A3A5A" Click="Button_Click_1"/>
        </StackPanel>

    </Grid>
</Window>
